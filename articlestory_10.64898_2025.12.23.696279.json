        "match": {
          "id": "PPR1230340",
          "source": "PPR",
          "doi": "10.64898/2025.12.23.696279",
          "title": "<i>Vibrio cholerae</i>  serotype impacts pathogenicity",
          "authorString": "Zingl FG, Leitner DR, Fakoya B, Morano AA, Waldor MK.",
          "authorList": {
            "author": [
              {
                "fullName": "Zingl FG",
                "firstName": "Franz",
                "lastName": "Zingl",
                "initials": "FG"
              },
              {
                "fullName": "Leitner DR",
